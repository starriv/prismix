# ===========================================
# Prismix - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ── Blockchain / RPC ──────────────────────────────────────────────────

# Alchemy API Key — auto-constructs RPC URLs for all supported networks
# Get one at https://dashboard.alchemy.com
# Supports: Ethereum, Polygon, Base, Arbitrum, Optimism, zkSync, Linea (mainnet + testnet)
# One key covers all networks — no need to configure per-network RPC URLs
ALCHEMY_API_KEY=

# ── Server ────────────────────────────────────────────────────────────

# Gateway domain — used by Caddy (HTTPS) and injected into the frontend
# at build time for displaying full gateway URLs (curl commands, endpoint hints).
# In local dev, leave unset — the UI falls back to window.location.origin.
# DOMAIN=gateway.example.com

# Server port (API + production SPA)
PORT=3403

# Log level: "fatal" | "error" | "warn" | "info" | "debug" | "trace"
# Default: "debug" in development, "info" in production
# Uses pino structured JSON logging (pino-pretty in dev)
# LOG_LEVEL=info

# Dev-only secret to enable test endpoints (/api/dev/admin-token)
# Set any value to activate dev endpoints. Left unset = dev endpoints disabled.
# DEV_SECRET=1

# Vite dev server port (development only)
VITE_DEV_PORT=5189

# Custom CORS origin override (optional, auto-detected in dev/production)
# CORS_ORIGIN=http://localhost:5189

# ── Crypto / Security ────────────────────────────────────────────────
# All three can be batch-generated with: pnpm generate-secrets
#
# JWT signing secret (required)
# Used for signing/verifying auth tokens
# Generate: openssl rand -hex 32
JWT_SECRET=

# AES-256 encryption key for credentials at rest (optional, falls back to JWT_SECRET)
# Used as PBKDF2 password input for AES-256-GCM encryption
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# PBKDF2 salt for key derivation (required)
# Domain separator for all encryption operations — must be unique per deployment
# Generate: openssl rand -hex 16
ENCRYPTION_SALT=

# ── Hot Wallet (Auto-Payout) ──────────────────────────────────────
# Private key for the platform hot wallet that sends USDC withdrawals automatically
# The hot wallet must hold USDC on each supported network (Polygon, Base)
# Generate: cast wallet new (or openssl rand -hex 32, prefix with 0x)
# Leave empty to disable automatic withdrawals (admin must send manually)
# PLATFORM_HOT_WALLET_KEY=


# ── Database ──────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
# Local dev (via pnpm dev:services): auto-injected by dev:server script
# Production: set to your PostgreSQL instance URL
DATABASE_URL=postgresql://prismix:prismix@localhost:15432/prismix

# PostgreSQL password for Docker deployment (used by deploy/production/docker-compose.yml)
# Default: prismix — change before deploying to production!
# POSTGRES_PASSWORD=prismix

# PostgreSQL connection pool max size (default: 20)
# DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────────────

# Redis connection URL — enables distributed cache, queue, and pub-sub
# Local dev (via pnpm dev:services): auto-injected by dev:server script
# Production: set to your Redis instance URL (include password if enabled)
# Format: redis://:password@host:port
REDIS_URL=redis://localhost:16379

# Redis password for Docker deployment (used by deploy/production/docker-compose.yml)
# Default: prismix — MUST change before deploying to production!
# Generate: openssl rand -hex 16
# REDIS_PASSWORD=prismix

# ── Supplier Health Check ────────────────────────────────────────────

# Interval between supplier connectivity checks (default: 1 min = 60000 ms)
# Each tick pings every enabled provider + their bound upstreams via /v1/models
# SUPPLIER_HEALTH_CHECK_INTERVAL_MS=60000

# Failed checks within the failure window before a supplier is considered unhealthy (default: 2)
# With the default 1 min interval + 3 min window, transient single-tick network blips do not alert
# SUPPLIER_HEALTH_CHECK_FAILURE_THRESHOLD=2

# Failure counting window (default: 3 min = 180000 ms)
# SUPPLIER_HEALTH_CHECK_FAILURE_WINDOW_MS=180000

# Timeout for a single supplier ping (default: 10 seconds)
# SUPPLIER_HEALTH_CHECK_TIMEOUT_MS=10000

# In-memory AI key pool refresh TTL (default: 30 seconds). CRUD APIs still
# invalidate immediately; this TTL covers direct DB repairs or missed events.
# AI_KEY_POOL_CACHE_TTL_MS=30000

# ── Client (Vite) ────────────────────────────────────────────────────

# WalletConnect project ID for RainbowKit
# Get one at https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
