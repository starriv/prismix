# ===========================================
# Prismix 环境变量模板
# ===========================================
# 复制此文件为 .env.local 并填入真实值：
#   cp .env.example .env.local
#
# 所有密钥可一次性生成（JWT_SECRET / ENCRYPTION_KEY / ENCRYPTION_SALT）：
#   pnpm generate-secrets

# ── 数据库 (PostgreSQL) ───────────────────────────────────────────────
# 连接串（必填）。本地开发由 pnpm dev:services 启动 docker postgres，
# dev:server 脚本会自动注入此变量。
DATABASE_URL=postgresql://prismix:prismix@localhost:15433/prismix

# 连接池最大连接数（默认 20）
# DB_POOL_MAX=20

# Docker 部署专用：deploy/production/docker-compose.yml 中 postgres 容器的密码
# 本地开发无需设置（dev-services.sh 已固定 prismix:prismix）
# POSTGRES_PASSWORD=prismix

# ── 缓存 / 队列 (Redis) ──────────────────────────────────────────────
# 连接串（必填）。BullMQ 队列、限流、语义缓存、跨实例事件总线都依赖它。
# 本地开发由 dev-services.sh 启动 docker redis 并自动注入。
REDIS_URL=redis://localhost:16378

# Docker 部署专用：deploy/production/docker-compose.yml 中 redis 容器的密码
# REDIS_PASSWORD=prismix

# ── 安全 / 加密 ───────────────────────────────────────────────────────
# 三个密钥均可通过 pnpm generate-secrets 一次性生成

# JWT 签名密钥（必填，至少 32 字符）
# 用于签发 / 验证 auth token
# 生成：openssl rand -hex 32
JWT_SECRET=

# AES-256-GCM 凭证加密密钥（可选，未设置时回退到 JWT_SECRET）
# 用于加密存储在 DB 中的上游 API Key、供应商凭证等
# 生成：openssl rand -hex 32
ENCRYPTION_KEY=

# PBKDF2 密钥派生盐值（必填，建议 16 字节 hex）
# 所有加密操作的 domain separator，每个部署环境必须唯一
# 生成：openssl rand -hex 16
ENCRYPTION_SALT=

# ── 服务器 ────────────────────────────────────────────────────────────
# API 服务监听端口（API 进程必填，worker 进程不用）
PORT=3403

# 进程角色 — 决定启动哪些子系统（Railway API/Worker 拆分用）
#   all    → 单进程：HTTP API + 后台任务（默认；本地开发和自托管）
#   api    → 仅 HTTP API，队列只生产不消费（可水平扩展）
#   worker → 仅后台任务 + 队列消费（必须用 pnpm start:worker 启动）
# 本地开发留空即可（默认 all）。pnpm dev:worker 会自动设 ROLE=worker。
# ROLE=all

# Worker 健康检查端口（仅 ROLE=worker 使用）。默认 3404。
# Railway worker 服务的 healthcheck 打这个端口的 /health。
# WORKER_HEALTH_PORT=3404

# 网关域名（可选，生产环境用）
# Caddy 用于 HTTPS，构建时注入前端用于显示完整网关 URL（curl 示例、端点提示）。
# 本地开发留空 — UI 回退到 window.location.origin。
# DOMAIN=gateway.example.com

# CORS 跨域来源覆盖（可选，dev/prod 自动推断）
# 不设时：dev 用 http://localhost:{VITE_DEV_PORT}，prod 同源
# CORS_ORIGIN=http://localhost:5189

# 日志级别："fatal" | "error" | "warn" | "info" | "debug" | "trace"
# 默认：dev=debug，prod=info。Pino 结构化 JSON（dev 用 pino-pretty）
# LOG_LEVEL=info

# Dev 专用密钥 — 启用测试端点 /api/dev/admin-token
# 设置任意值即激活，留空 = 禁用 dev 端点
# DEV_SECRET=1

# ── Vite 开发服务器（仅开发） ────────────────────────────────────────
# Vite dev server 端口（仅开发环境）
VITE_DEV_PORT=5189

# ── 前端（Vite，客户端可见） ─────────────────────────────────────────
# WalletConnect 项目 ID（RainbowKit 用）
# 申请：https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# ── 区块链 / RPC ─────────────────────────────────────────────────────
# Alchemy API Key — 自动构造所有支持网络的 RPC URL
# 申请：https://dashboard.alchemy.com
# 支持：Ethereum / Polygon / Base / Arbitrum / Optimism / zkSync / Linea（主网 + 测试网）
# 一个 key 覆盖所有网络，无需逐网络配置 RPC URL
ALCHEMY_API_KEY=

# ── 热钱包（自动提现） ───────────────────────────────────────────────
# 平台热钱包私钥 — 自动发送 USDC 提现
# 热钱包需在每个支持网络（Polygon / Base）上持有 USDC 余额
# 生成：cast wallet new（或 openssl rand -hex 32，加 0x 前缀）
# 留空则禁用自动提现（管理员需手动发送）
# PLATFORM_HOT_WALLET_KEY=0x...

# ── AI 网关 — 日志保留 ───────────────────────────────────────────────
# 请求/响应 body 的 Redis TTL（天）。存于 Redis key ai-req:{requestId}，
# 到期自动过期，无需 job 清理。默认 7 天。
# AI_REQUEST_LOG_TTL_DAYS=7

# 用量日志（ai_usage_logs 表）的 PG 保留天数。
# cleanup-ai-usage-logs job 每小时跑一次，删除超过此天数的行。默认 7 天。
# AI_USAGE_LOG_RETENTION_DAYS=7

# ── AI 网关 — 缓存与告警 ─────────────────────────────────────────────
# 内存中 AI Key 池刷新 TTL（默认 30 秒）。
# CRUD API 会立即失效缓存；此 TTL 仅覆盖直接 DB 修复或事件丢失场景。
# AI_KEY_POOL_CACHE_TTL_MS=30000

# "所有上游候选失败" 资源不可用告警的冷却时间（默认 5 分钟）。
# 防止一次故障刷屏通知渠道。
# RESOURCE_DOWN_ALERT_COOLDOWN_MS=300000

# ── 供应商健康检查 ───────────────────────────────────────────────────
# 检查间隔（默认 60 秒）。每个 tick ping 所有启用的供应商 + 绑定上游的 /v1/models
# SUPPLIER_HEALTH_CHECK_INTERVAL_MS=60000

# 失败窗口内连续失败几次后判定供应商不健康（默认 2 次）
# 默认 1 分钟间隔 + 3 分钟窗口 = 单次网络抖动不会误报
# SUPPLIER_HEALTH_CHECK_FAILURE_THRESHOLD=2

# 失败计数窗口（默认 3 分钟）
# SUPPLIER_HEALTH_CHECK_FAILURE_WINDOW_MS=180000

# 单次供应商 ping 超时（默认 10 秒）
# SUPPLIER_HEALTH_CHECK_TIMEOUT_MS=10000
