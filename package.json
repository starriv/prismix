{
  "name": "prismix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm dev:services && concurrently -k -n api,web -c green,blue \"pnpm dev:server\" \"pnpm dev:web:wait\"",
    "dev:services": "bash scripts/dev-services.sh",
    "dev:services:stop": "bash scripts/dev-services.sh stop",
    "dev:services:status": "bash scripts/dev-services.sh status",
    "dev:web": "vite",
    "dev:web:wait": "node scripts/wait-for-server.mjs && vite",
    "dev:server": "tsx watch --env-file=.env.local src/server/index.ts",
    "dev:worker": "ROLE=worker WORKER_HEALTH_PORT=3404 tsx watch --env-file=.env.local src/server/worker.ts",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "build:server": "tsup",
    "start": "node dist/server/index.js",
    "start:worker": "ROLE=worker node dist/server/worker.js",
    "preview": "node --env-file=.env.local dist/server/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:e2e": "playwright test --config src/__tests__/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config src/__tests__/e2e/playwright.config.ts --ui",
    "test:integration": "vitest run src/__tests__/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm dev:services && drizzle-kit generate",
    "db:migrate": "pnpm dev:services && drizzle-kit migrate",
    "db:push": "pnpm dev:services && drizzle-kit push",
    "db:studio": "pnpm dev:services && drizzle-kit studio",
    "db:reset": "pnpm dev:services && tsx --env-file=.env.local scripts/db-reset.ts",
    "generate-secrets": "tsx scripts/generate-secrets.ts",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-saml/node-saml": "^5.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/lodash-es": "^4.17.12",
    "argon2": "^0.44.0",
    "bignumber.js": "^10.0.2",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "nuqs": "^2.8.9",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode.react": "^4.2.0",
    "quickjs-emscripten": "^0.32.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react18-json-view": "^0.2.10",
    "recharts": "3.8.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.47.10",
    "wagmi": "^2.19.5",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "argon2"
    ],
    "overrides": {
      "axios": "1.13.6"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
